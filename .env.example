# =============================================================================
# .env.example — Copy to .env and fill in your values
# =============================================================================

# Project paths (use absolute paths)
DATA_ROOT=./data
CHECKPOINT_DIR=./checkpoints
LOG_DIR=./logs
OUTPUT_DIR=./outputs

# WandB (optional — get API key from https://wandb.ai/settings)
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=pansharpening_pro

# GPU device (0 for first GPU, "0,1" for multi-GPU)
CUDA_VISIBLE_DEVICES=0
